.inventory-page {
  padding-top: 18rpx;
  padding-bottom: 180rpx;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.back-button,
.page-spacer {
  width: 72rpx;
  height: 72rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #10233f;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #10233f;
}

.state-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #10233f;
}

.state-text {
  margin-top: 14rpx;
  color: #6b7a8c;
  line-height: 1.7;
}

.error-card {
  border: 2rpx solid #ffd7d7;
}

.inventory-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.inventory-card {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.inventory-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.inventory-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #10233f;
}

.inventory-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4f5f73;
}

.inventory-status {
  margin-top: 10rpx;
}

.inventory-right {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.remain-ring {
  width: 124rpx;
  height: 124rpx;
  border-radius: 999rpx;
  border: 10rpx solid #5ca0ff;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.remain-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #10233f;
}

.edit-button {
  width: 132rpx;
  height: 60rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 2rpx solid #8bb3ff;
  background: #ffffff;
  color: #3559c7;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
