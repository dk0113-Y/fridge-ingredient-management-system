.home-page {
  padding-top: 18rpx;
  padding-bottom: 180rpx;
}

.top-row {
  display: block;
  margin-bottom: 22rpx;
}

.greeting {
  font-size: 42rpx;
  font-weight: 700;
  color: #10233f;
}

.date-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5f6f82;
}

.summary-card {
  padding: 22rpx;
}

.summary-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.summary-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.summary-status-online {
  background: #31bf72;
}

.summary-sync {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.summary-grid {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.summary-cell {
  flex: 1;
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  text-align: center;
}

.summary-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
}

.summary-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
}

.error-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 2rpx solid #ffd7d7;
}

.error-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #10233f;
}

.error-text {
  margin-top: 12rpx;
  color: #6b7a8c;
  line-height: 1.7;
}

.feature-grid {
  margin-top: 22rpx;
  display: flex;
}

.feature-card {
  width: 100%;
  min-height: 168rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  padding: 28rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.feature-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: #eef4ff;
  color: #4f8ff4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.feature-title {
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #10233f;
}
