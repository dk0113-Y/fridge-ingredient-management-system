{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage-1 Fridge Event Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "timestamp",
    "event_type",
    "roi_id",
    "confidence",
    "before_frame",
    "after_frame",
    "change_regions",
    "objects",
    "need_user_confirm"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "no_change",
        "put_in",
        "take_out",
        "partial_take_out_candidate"
      ]
    },
    "roi_id": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "before_frame": {
      "type": "string"
    },
    "after_frame": {
      "type": "string"
    },
    "change_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "width",
          "height",
          "score"
        ],
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "score": {
            "type": "number",
            "minimum": 0.0
          }
        }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "name",
          "count_delta",
          "remain_level"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "count_delta": {
            "type": "integer"
          },
          "remain_level": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },
    "need_user_confirm": {
      "type": "boolean"
    }
  }
}
